#!/bin/bash
EXERCISE_DIR="/workspace/exercise"
INVENTORY="$EXERCISE_DIR/inventory_workflow.go"
FULFILLMENT="$EXERCISE_DIR/fulfillment_workflow.go"

fail() { echo "FAIL: $1"; exit 1; }
pass() { echo "PASS: $1"; }

if grep -q "return \"\", nil // replace this" "$INVENTORY"; then
  fail "InventoryReservationWorkflow still has the placeholder return. Implement Parts A and B."
fi
pass "InventoryReservationWorkflow placeholder removed"

if ! grep -q "ExecuteActivity" "$INVENTORY"; then
  fail "InventoryReservationWorkflow is missing workflow.ExecuteActivity() calls. Iterate over Warehouses."
fi
pass "ExecuteActivity used in InventoryReservationWorkflow"

if ! grep -q "OutOfStock" "$INVENTORY"; then
  fail "InventoryReservationWorkflow is missing a non-retryable ApplicationError with type \"OutOfStock\"."
fi
pass "OutOfStock error present"

if grep -q "REMOVE THIS BLOCK" "$FULFILLMENT"; then
  fail "FulfillmentWorkflow still has the placeholder block. Replace it with ExecuteChildWorkflow."
fi
pass "Placeholder block removed from FulfillmentWorkflow"

if ! grep -q "ExecuteChildWorkflow" "$FULFILLMENT"; then
  fail "FulfillmentWorkflow is missing workflow.ExecuteChildWorkflow(). Call InventoryReservationWorkflow as a child."
fi
pass "ExecuteChildWorkflow present in FulfillmentWorkflow"

if ! grep -q "ChildWorkflowOptions" "$FULFILLMENT"; then
  fail "FulfillmentWorkflow is missing ChildWorkflowOptions. Set WorkflowID = \"inventory-\" + order.OrderID."
fi
pass "ChildWorkflowOptions configured"

echo "Running go build..."
cd "$EXERCISE_DIR"
if ! go build ./... 2>&1; then
  fail "Project does not build. Fix compilation errors above and try again."
fi
pass "Project builds successfully"

echo ""
echo "All checks passed! Find fulfillment-ORD-1001 and inventory-ORD-1001 in the Web UI."
